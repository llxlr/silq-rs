// Deutsch 算法 - 判断函数是常数还是平衡
// 运行: silq --run test/deutsch.slq

def solve(const O_f: B x B !-> B x B) {
    x := H(0);
    y := H(1);
    (x, y) := O_f(x, y);
    x := H(x);
    measure(y);          // 丢弃 y
    return measure(x);   // 0 = 常数, 1 = 平衡
}

def main() {
    // 四种 oracle 类型
    def O_id(x: B, y: B) {
        y xor= x;
        return (x, y);
    }
    def O_not(x: B, y: B) {
        y xor= !x;
        return (x, y);
    }
    def O_zero(x: B, y: B) {
        y xor= 0;
        return (x, y);
    }
    def O_one(x: B, y: B) {
        y xor= 1;
        return (x, y);
    }

    assert(solve(O_id));     // id 是平衡的 → 1
    assert(solve(O_not));    // not 是平衡的 → 1
    assert(!solve(O_zero));  // zero 是常数的 → 0
    assert(!solve(O_one));   // one 是常数的 → 0
}
